<Window x:Class="Labs.RemotePlay.PsnLoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Sign in with PSN" Height="720" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Bg}" Foreground="{StaticResource Text}"
        FontFamily="Segoe UI" FontSize="13">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Surface}" Padding="16,10">
            <TextBlock Name="StatusText" Text="Loading PSN sign-in…" Foreground="{StaticResource TextMuted}"/>
        </Border>

        <wv2:WebView2 Grid.Row="1" Name="Web"/>

        <Border Grid.Row="2" Background="{StaticResource Surface}" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="Cancel_Click" Padding="16,8"
                        Background="Transparent" Foreground="{StaticResource Text}" BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
