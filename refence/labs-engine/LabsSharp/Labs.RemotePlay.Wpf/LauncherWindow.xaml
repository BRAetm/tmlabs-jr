<Window x:Class="Labs.RemotePlay.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="labs launcher" Height="720" Width="1220"
        Background="{StaticResource Bg}" Foreground="{StaticResource Text}"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>   <!-- top bar -->
            <RowDefinition Height="*"/>    <!-- body   -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TOP BAR · brand (left) + nav (right) -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Background="{StaticResource BgSubtle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="28,0,0,0">
                <Border Width="22" Height="22" CornerRadius="4" Background="{StaticResource Accent}"/>
                <TextBlock Text="labs launcher" Margin="12,0,0,0"
                           FontFamily="{StaticResource FontDisplay}" FontSize="16"
                           FontWeight="SemiBold" Foreground="{StaticResource Text}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="LIBRARY"   Style="{StaticResource Eyebrow}" Foreground="{StaticResource Text}" Margin="18,0"/>
                <TextBlock Text="STORE"     Style="{StaticResource Eyebrow}" Foreground="{StaticResource TextDim}" Margin="18,0"/>
                <TextBlock Text="LABS+"     Style="{StaticResource Eyebrow}" Foreground="{StaticResource TextDim}" Margin="18,0"/>
                <TextBlock Text="SETTINGS"  Style="{StaticResource Eyebrow}" Foreground="{StaticResource TextDim}" Margin="18,0"/>
            </StackPanel>

            <Button Grid.Column="2" Content="exit" Style="{StaticResource BtnQuiet}"
                    Click="Exit_Click" Margin="0,0,28,0"/>
        </Grid>

        <!-- LEFT RAIL · tool list (RGL "library" column) -->
        <Grid Grid.Row="1" Grid.Column="0" Background="{StaticResource BgSubtle}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="MY TOOLS" Style="{StaticResource Eyebrow}"
                       Margin="28,22,28,10"/>

            <ListBox Grid.Row="1" Name="ToolList" Background="Transparent" BorderThickness="0"
                     Foreground="{StaticResource Text}" Padding="12,0,12,12"
                     SelectedIndex="0"
                     SelectionChanged="ToolList_SelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="12,10"/>
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="{StaticResource Text}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            CornerRadius="2" Padding="{TemplateBinding Padding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Rectangle x:Name="Marker" Grid.Column="0" Fill="Transparent" Width="3"
                                                       HorizontalAlignment="Left"/>
                                            <ContentPresenter Grid.Column="1" Margin="10,0,0,0"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface}"/>
                                            <Setter TargetName="Marker" Property="Fill" Value="{StaticResource Accent}"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                                <Condition Property="IsSelected" Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface}"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBoxItem>
                    <StackPanel>
                        <TextBlock Text="labs engine" FontFamily="{StaticResource FontDisplay}"
                                   FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource Text}"/>
                        <TextBlock Text="stream your PS5" Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                </ListBoxItem>

                <ListBoxItem>
                    <StackPanel>
                        <TextBlock Text="zen coder" FontFamily="{StaticResource FontDisplay}"
                                   FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource Text}"/>
                        <TextBlock Text="focused writing space" Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                </ListBoxItem>

                <ListBoxItem>
                    <StackPanel>
                        <TextBlock Text="cv script builder" FontFamily="{StaticResource FontDisplay}"
                                   FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource Text}"/>
                        <TextBlock Text="vision scripts · ai authored" Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                </ListBoxItem>
            </ListBox>

            <StackPanel Grid.Row="2" Margin="28,0,28,24">
                <TextBlock Text="VERSION" Style="{StaticResource Eyebrow}"/>
                <TextBlock Text="0.1 · preview" Style="{StaticResource Caption}" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- MAIN STAGE · hero that swaps per selected tool -->
        <Grid Grid.Row="1" Grid.Column="1">

            <!-- ===== labs engine HERO ===== -->
            <Border Name="HeroEngine" Visibility="Visible"
                    Background="{StaticResource HeroGradient}" ClipToBounds="True">
                <Grid>
                    <!-- atmospheric blue glow, corner -->
                    <Ellipse HorizontalAlignment="Right" VerticalAlignment="Top"
                             Width="900" Height="900" Margin="0,-260,-260,0" Opacity="0.28">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#3B82F6" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <!-- diagonal streaks for motion -->
                    <Path Stroke="#1F60A5FA" StrokeThickness="1" HorizontalAlignment="Right"
                          VerticalAlignment="Stretch" Margin="0,0,120,0"
                          Data="M 0 0 L 220 700"/>
                    <Path Stroke="#1760A5FA" StrokeThickness="1" HorizontalAlignment="Right"
                          VerticalAlignment="Stretch" Margin="0,0,60,0"
                          Data="M 0 0 L 220 700"/>

                    <!-- top accent line -->
                    <Rectangle HorizontalAlignment="Stretch" VerticalAlignment="Top"
                               Height="2" Fill="{StaticResource AccentLine}"/>

                    <!-- content -->
                    <StackPanel VerticalAlignment="Bottom" Margin="56,0,56,56">
                        <TextBlock Text="FEATURED · 01" Style="{StaticResource Eyebrow}"
                                   Margin="0,0,0,16"/>
                        <TextBlock Text="labs engine"
                                   FontFamily="{StaticResource FontDisplay}" FontSize="96"
                                   FontWeight="Bold" Foreground="{StaticResource Text}"
                                   LineHeight="90" Margin="-4,0,0,0"/>
                        <TextBlock Text="stream your PS5 to this PC at 1080p60. lan or remote."
                                   Style="{StaticResource Body}" FontSize="16"
                                   Foreground="{StaticResource TextMuted}" Margin="0,14,0,28"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Click="LaunchEngine_Click" Cursor="Hand" BorderThickness="0" Padding="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Pb" Background="White" CornerRadius="2" Padding="44,14">
                                            <TextBlock Text="START" Foreground="Black"
                                                       FontFamily="{StaticResource FontDisplay}"
                                                       FontWeight="Bold" FontSize="16"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Pb" Property="Background" Value="{StaticResource Blue200}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <StackPanel Margin="28,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="1080p60 · H.264 · 15 mbps"
                                           Style="{StaticResource Caption}"
                                           FontFamily="{StaticResource FontMono}"/>
                                <TextBlock Text="last played — never"
                                           Style="{StaticResource Caption}"
                                           FontFamily="{StaticResource FontMono}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== cv script builder HERO ===== -->
            <Border Name="HeroCv" Visibility="Collapsed" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0A1210" Offset="0"/>
                        <GradientStop Color="#0D1B18" Offset="0.6"/>
                        <GradientStop Color="#040807" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Ellipse HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Width="900" Height="900" Margin="-260,0,0,-260" Opacity="0.25">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#30E8A0" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Rectangle HorizontalAlignment="Stretch" VerticalAlignment="Top"
                               Height="2" Fill="{StaticResource AccentLine}"/>
                    <StackPanel VerticalAlignment="Bottom" Margin="56,0,56,56">
                        <TextBlock Text="FEATURED · 03" Style="{StaticResource Eyebrow}" Margin="0,0,0,16"/>
                        <TextBlock Text="cv script builder"
                                   FontFamily="{StaticResource FontDisplay}" FontSize="86"
                                   FontWeight="Bold" Foreground="{StaticResource Text}"
                                   LineHeight="82" Margin="-4,0,0,0"/>
                        <TextBlock Text="ai authors the vision script live. pick a source, start a session."
                                   Style="{StaticResource Body}" FontSize="16"
                                   Foreground="{StaticResource TextMuted}" Margin="0,14,0,28"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Click="LaunchCvRemote_Click" Cursor="Hand" BorderThickness="0" Padding="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="PbR" Background="White" CornerRadius="2" Padding="36,14">
                                            <TextBlock Text="REMOTE PLAY" Foreground="Black"
                                                       FontFamily="{StaticResource FontDisplay}"
                                                       FontWeight="Bold" FontSize="16"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="PbR" Property="Background" Value="{StaticResource Blue200}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Click="LaunchCvCapture_Click" Cursor="Hand" BorderThickness="0" Padding="0" Margin="14,0,0,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="PbC" Background="#22FFFFFF" CornerRadius="2" Padding="36,14">
                                            <TextBlock Text="CAPTURE CARD" Foreground="{StaticResource Text}"
                                                       FontFamily="{StaticResource FontDisplay}"
                                                       FontWeight="Bold" FontSize="16"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="PbC" Property="Background" Value="#40FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <StackPanel Margin="28,0,0,0" VerticalAlignment="Center">
                                <TextBlock Name="CvStatusLine1" Text="python · pyside6 · ultralytics"
                                           Style="{StaticResource Caption}"
                                           FontFamily="{StaticResource FontMono}"/>
                                <TextBlock Name="CvStatusLine2" Text="pick a source to begin"
                                           Style="{StaticResource Caption}"
                                           FontFamily="{StaticResource FontMono}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== zen coder HERO ===== -->
            <Border Name="HeroZen" Visibility="Collapsed" ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0B1020" Offset="0"/>
                        <GradientStop Color="#0F172A" Offset="0.6"/>
                        <GradientStop Color="#050812" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- soft faint horizontal bands → writing feel -->
                    <Rectangle HorizontalAlignment="Stretch" VerticalAlignment="Top"
                               Height="2" Fill="{StaticResource AccentLine}"/>
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center"
                                Margin="0,0,80,0" Opacity="0.22">
                        <Rectangle Height="1" Width="360" Fill="#60A5FA" Margin="0,8"/>
                        <Rectangle Height="1" Width="300" Fill="#60A5FA" Margin="0,8"/>
                        <Rectangle Height="1" Width="340" Fill="#60A5FA" Margin="0,8"/>
                        <Rectangle Height="1" Width="260" Fill="#60A5FA" Margin="0,8"/>
                        <Rectangle Height="1" Width="320" Fill="#60A5FA" Margin="0,8"/>
                    </StackPanel>

                    <StackPanel VerticalAlignment="Bottom" Margin="56,0,56,56">
                        <TextBlock Text="FEATURED · 02" Style="{StaticResource Eyebrow}" Margin="0,0,0,16"/>
                        <TextBlock Text="zen coder"
                                   FontFamily="{StaticResource FontDisplay}" FontSize="96"
                                   FontWeight="Bold" Foreground="{StaticResource Text}"
                                   LineHeight="90" Margin="-4,0,0,0"/>
                        <TextBlock Text="a distraction-free writing and code space. coming soon."
                                   Style="{StaticResource Body}" FontSize="16"
                                   Foreground="{StaticResource TextMuted}" Margin="0,14,0,28"/>
                        <StackPanel Orientation="Horizontal">
                            <Button IsEnabled="False" Cursor="Arrow" BorderThickness="0" Padding="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="#22FFFFFF" CornerRadius="2" Padding="44,14">
                                            <TextBlock Text="SOON" Foreground="{StaticResource TextMuted}"
                                                       FontFamily="{StaticResource FontDisplay}"
                                                       FontWeight="Bold" FontSize="16"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <StackPanel Margin="28,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="in development"
                                           Style="{StaticResource Caption}"
                                           FontFamily="{StaticResource FontMono}"/>
                                <TextBlock Text="status — planning"
                                           Style="{StaticResource Caption}"
                                           FontFamily="{StaticResource FontMono}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>
