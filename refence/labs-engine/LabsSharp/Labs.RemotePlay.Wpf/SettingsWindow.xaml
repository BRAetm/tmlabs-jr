<Window x:Class="Labs.RemotePlay.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="420" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource Bg}" Foreground="{StaticResource Text}"
        FontFamily="Segoe UI" FontSize="14">
    <StackPanel Margin="24">
        <TextBlock Text="Stream settings" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <TextBlock Text="Resolution" Margin="0,8,0,4"/>
        <ComboBox Name="ResolutionBox" Background="{StaticResource Surface}" Foreground="{StaticResource Text}" Padding="8" BorderThickness="0">
            <ComboBoxItem Content="720p"/>
            <ComboBoxItem Content="1080p" IsSelected="True"/>
        </ComboBox>

        <TextBlock Text="Frame rate" Margin="0,16,0,4"/>
        <ComboBox Name="FpsBox" Background="{StaticResource Surface}" Foreground="{StaticResource Text}" Padding="8" BorderThickness="0">
            <ComboBoxItem Content="30"/>
            <ComboBoxItem Content="60" IsSelected="True"/>
        </ComboBox>

        <TextBlock Text="Codec" Margin="0,16,0,4"/>
        <ComboBox Name="CodecBox" Background="{StaticResource Surface}" Foreground="{StaticResource Text}" Padding="8" BorderThickness="0">
            <ComboBoxItem Content="H264"/>
            <ComboBoxItem Content="H265" IsSelected="True"/>
        </ComboBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,32,0,0">
            <Button Content="Close" Click="Close_Click" Padding="16,8"
                    Background="{StaticResource Accent}" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </StackPanel>
</Window>
