<Window x:Class="Labs.RemotePlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:panels="clr-namespace:Labs.RemotePlay.Panels"
        Title="labs engine" Height="800" Width="1280"
        Background="{StaticResource Bg}" Foreground="{StaticResource Text}"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True">
    <Window.Resources>
        <Style x:Key="Section" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontDisplay}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        </Style>
        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>     <!-- scripts rail -->
            <ColumnDefinition Width="*"/>        <!-- stage        -->
            <ColumnDefinition Width="260"/>      <!-- devices rail -->
        </Grid.ColumnDefinitions>

        <!-- ====== top bar ====== -->
        <Grid Grid.Row="0" Grid.ColumnSpan="3" Background="{StaticResource BgSubtle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <Button Content="←" Style="{StaticResource BtnQuiet}" Padding="4,0" Click="Back_Click"/>
                <TextBlock Text="labs engine" Margin="14,0,0,0"
                           FontFamily="{StaticResource FontDisplay}" FontSize="17" FontWeight="SemiBold"
                           Foreground="{StaticResource Text}" VerticalAlignment="Center"/>
                <TextBlock Text="· 0.1" Margin="8,0,0,0"
                           FontFamily="{StaticResource FontMono}" FontSize="11"
                           Foreground="{StaticResource TextDim}" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0">
                <Button x:Name="MuteBtn" Content="mute" Style="{StaticResource BtnQuiet}" Margin="8,0" Click="Mute_Click"/>
                <Button Content="save profile" Style="{StaticResource BtnQuiet}" Margin="8,0"/>
                <Button Content="load profile" Style="{StaticResource BtnQuiet}" Margin="8,0"/>
                <Button Content="train cv"     Style="{StaticResource BtnQuiet}" Margin="8,0"/>
                <Button Content="+ new session" Style="{StaticResource BtnPrimary}" Margin="12,0,0,0" Click="NewSession_Click"/>
            </StackPanel>
        </Grid>

        <!-- ====== LEFT RAIL · scripts ====== -->
        <Grid Grid.Row="1" Grid.Column="0" Background="{StaticResource BgSubtle}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- scripts header + controls -->
            <StackPanel Grid.Row="0" Margin="22,22,22,0">
                <DockPanel LastChildFill="False">
                    <TextBlock Text="scripts" Style="{StaticResource Section}" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="+" Style="{StaticResource BtnQuiet}" Padding="6,0"/>
                    <Button DockPanel.Dock="Right" Content="⟳" ToolTip="refresh script list" Style="{StaticResource BtnQuiet}" Padding="6,0" Margin="0,0,6,0" Click="RefreshScripts_Click"/>
                </DockPanel>

                <TextBlock Text="active script" Style="{StaticResource Label}" Margin="0,14,0,4"/>
                <ComboBox x:Name="ScriptCombo" SelectionChanged="ScriptCombo_Changed">
                    <ComboBoxItem Content="(none)" IsSelected="True"/>
                </ComboBox>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="run"  Style="{StaticResource BtnPrimary}" Margin="0,0,4,0" Click="RunScript_Click"/>
                    <Button Grid.Column="1" Content="stop" Style="{StaticResource BtnGhost}"  Margin="4,0,0,0" Click="StopScript_Click"/>
                </Grid>

                <TextBlock Margin="0,12,0,0" FontFamily="{StaticResource FontBody}" FontSize="12">
                    <Run Text="status " Foreground="{StaticResource TextMuted}"/>
                    <Run Text="idle" FontFamily="{StaticResource FontMono}" Foreground="{StaticResource TextMuted}"/>
                </TextBlock>

                <Border Height="1" Background="{StaticResource BorderSoft}" Margin="0,16"/>

                <TextBlock Text="script library" Style="{StaticResource Section}"/>
            </StackPanel>

            <!-- scripts list -->
            <ListBox Grid.Row="1" x:Name="ScriptList" Background="Transparent" BorderThickness="0" Padding="12,8,12,12"
                     Foreground="{StaticResource Text}" SelectionChanged="ScriptList_SelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,0,0,1"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- status area for selected script -->
            <StackPanel Grid.Row="2" Margin="22,0,22,22">
                <TextBlock Text="no script selected, so there's nothing to configure yet."
                           Style="{StaticResource Label}" TextWrapping="Wrap"/>
                <Button Content="open scripts folder…" Style="{StaticResource BtnQuiet}"
                        HorizontalAlignment="Left" Margin="0,8,0,0" Click="OpenScriptsFolder_Click"/>
            </StackPanel>
        </Grid>

        <!-- ====== CENTER STAGE ====== -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="180"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="22,22,22,10">
                <Border Name="SessionHost" Visibility="Collapsed"
                        BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="3"
                        ClipToBounds="True"/>
                <Border Name="EmptyStage" Background="{StaticResource Surface}"
                        BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="3">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="420">
                        <TextBlock Text="no active session"
                                   FontFamily="{StaticResource FontDisplay}" FontSize="22"
                                   FontWeight="SemiBold" Foreground="{StaticResource Text}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="start one from + new session in the top bar, or drop a capture source onto this window."
                                   Style="{StaticResource Label}" Margin="0,10,0,0" TextAlignment="Center"
                                   TextWrapping="Wrap"/>
                        <Button Content="+ new session" Style="{StaticResource BtnPrimary}"
                                Margin="0,22,0,0" HorizontalAlignment="Center" Click="NewSession_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- output log -->
            <Grid Grid.Row="1" Margin="22,0,22,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock Text="output" Style="{StaticResource Section}" DockPanel.Dock="Left"/>
                    <Button DockPanel.Dock="Right" Content="clear" Style="{StaticResource BtnQuiet}"/>
                </DockPanel>
                <Border Grid.Row="1" Background="{StaticResource Surface}"
                        BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock Name="LogOutput" Margin="12,10"
                                   FontFamily="{StaticResource FontMono}" FontSize="11"
                                   Foreground="{StaticResource TextMuted}" TextWrapping="NoWrap"
                                   Text="engine idle — waiting for a session.&#x0a;devices: titan not found, gpc3 available.&#x0a;remote play engine ready.&#x0a;"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- ====== RIGHT RAIL · devices / capture / titan ====== -->
        <Grid Grid.Row="1" Grid.Column="2" Background="{StaticResource BgSubtle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="22,22,22,22">

                    <!-- capture -->
                    <TextBlock Text="capture" Style="{StaticResource Section}"/>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Label}" Text="source"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Value}" Text="DirectShow"  TextAlignment="Right"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Label}" Text="resolution"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource Value}" Text="1280 × 720" TextAlignment="Right"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource Label}" Text="fps"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource Value}" Text="60"  TextAlignment="Right"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource BorderSoft}" Margin="0,20"/>

                    <!-- titan bridge -->
                    <DockPanel LastChildFill="False">
                        <TextBlock Text="titan bridge" Style="{StaticResource Section}"/>
                        <TextBlock x:Name="TitanStatusText" Text="not connected" Style="{StaticResource Label}" DockPanel.Dock="Right"
                                   FontFamily="{StaticResource FontMono}"/>
                    </DockPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button x:Name="TitanConnectBtn" Content="connect titan" Style="{StaticResource BtnQuiet}"
                                Click="TitanConnect_Click" Margin="0,0,6,0"/>
                        <Button x:Name="TitanScanBtn" Content="scan" Style="{StaticResource BtnQuiet}" Click="TitanScan_Click"/>
                    </StackPanel>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.Resources>
                            <Style x:Key="Slot" TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource Surface}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="CornerRadius" Value="2"/>
                                <Setter Property="Margin" Value="2"/>
                                <Setter Property="Padding" Value="8,8"/>
                                <Setter Property="Height" Value="54"/>
                            </Style>
                        </Grid.Resources>
                        <Border Grid.Column="0" Style="{StaticResource Slot}">
                            <StackPanel>
                                <TextBlock Text="slot 1" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                <TextBlock Text="empty" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{StaticResource TextDim}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource Slot}">
                            <StackPanel>
                                <TextBlock Text="slot 2" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                <TextBlock Text="empty" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{StaticResource TextDim}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource Slot}">
                            <StackPanel>
                                <TextBlock Text="slot 3" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                <TextBlock Text="empty" FontFamily="{StaticResource FontMono}" FontSize="11" Foreground="{StaticResource TextDim}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <TextBlock Text="console → titan (offline) → controller"
                               Style="{StaticResource Label}" FontFamily="{StaticResource FontMono}"
                               Margin="0,10,0,0"/>

                    <Border Height="1" Background="{StaticResource BorderSoft}" Margin="0,20"/>

                    <!-- controller monitor -->
                    <TextBlock Text="controller monitor" Style="{StaticResource Section}"/>
                    <panels:ControllerMonitorView x:Name="Monitor" Margin="0,10,0,0"/>

                    <Border Height="1" Background="{StaticResource BorderSoft}" Margin="0,20"/>

                    <!-- devices -->
                    <TextBlock Text="devices" Style="{StaticResource Section}"/>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Label}" Text="vigem"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Value}" Text="connected" TextAlignment="Right" Foreground="{StaticResource Success}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Label}" Text="titan"/>
                        <TextBlock x:Name="TitanDeviceStatus" Grid.Row="1" Grid.Column="1" Style="{StaticResource Value}" Text="not found" TextAlignment="Right" Foreground="{StaticResource TextDim}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource Label}" Text="gpc3"/>
                        <TextBlock x:Name="GpcStatusText" Grid.Row="2" Grid.Column="1" Style="{StaticResource Value}" Text="available" TextAlignment="Right" Foreground="{StaticResource Success}"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ====== status ====== -->
        <Grid Grid.Row="2" Grid.ColumnSpan="3" Background="{StaticResource BgSubtle}">
            <TextBlock VerticalAlignment="Center" Margin="20,0"
                       FontFamily="{StaticResource FontMono}" FontSize="11"
                       Foreground="{StaticResource TextDim}">
                <Run Foreground="{StaticResource Success}" Text="ready"/>
                <Run Text=" · labs engine 0.1"/>
            </TextBlock>
        </Grid>
    </Grid>
</Window>
