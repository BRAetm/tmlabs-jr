<Window x:Class="Labs.RemotePlay.StreamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Streaming" Height="720" Width="1280"
        Background="Black" Foreground="White"
        FontFamily="Segoe UI" FontSize="14"
        WindowState="Normal">
    <Grid>
        <Image Name="VideoSurface" Stretch="Uniform"/>
        <TextBlock Name="Overlay" Text="Connecting…" Foreground="White"
                   HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24"/>
        <TextBlock Name="Hud" Foreground="#80FFFFFF" FontSize="11"
                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12"/>
    </Grid>
</Window>
