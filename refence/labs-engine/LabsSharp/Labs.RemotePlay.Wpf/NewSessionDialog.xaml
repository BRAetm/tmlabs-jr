<Window x:Class="Labs.RemotePlay.NewSessionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="pick capture method" Height="600" Width="780"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource Bg}" Foreground="{StaticResource Text}"
        UseLayoutRounding="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>    <!-- header   -->
            <RowDefinition Height="*"/>       <!-- hero     -->
            <RowDefinition Height="Auto"/>    <!-- row      -->
            <RowDefinition Height="Auto"/>    <!-- footer   -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="32,26,32,18">
            <TextBlock Text="LABS ENGINE" Style="{StaticResource Eyebrow}"/>
            <TextBlock Text="pick capture method" Style="{StaticResource H2}" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- ============ HERO · CAPTURE CARD ============ -->
        <Button Grid.Row="1" Margin="32,0,32,0" Click="CaptureCard_Click" Cursor="Hand"
                BorderThickness="0" Padding="0"
                HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border Background="{StaticResource HeroGradient}" CornerRadius="3" ClipToBounds="True">
                <ContentPresenter/>
              </Border>
            </ControlTemplate>
          </Button.Template>
        <Border Background="Transparent"
                CornerRadius="3" ClipToBounds="True">
            <Grid>
                <Rectangle HorizontalAlignment="Stretch" VerticalAlignment="Top"
                           Height="2" Fill="{StaticResource AccentLine}"/>

                <!-- HDMI-connector silhouette cluster on the right -->
                <Grid HorizontalAlignment="Right" VerticalAlignment="Center"
                      Margin="0,0,44,0" Width="210" Height="170" Opacity="0.9">
                    <Ellipse Opacity="0.18">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#60A5FA" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <!-- stylized capture device: HDMI in (top) → box → USB out (bottom) -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Rectangle Width="70" Height="8" Fill="#4060A5FA" RadiusX="1" RadiusY="1"/>
                        <Rectangle Width="2"  Height="18" Fill="#4060A5FA" HorizontalAlignment="Center"/>
                        <Border Width="120" Height="60" CornerRadius="3"
                                Background="#141C36" BorderBrush="#60A5FA" BorderThickness="1">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="CAPTURE" FontFamily="{StaticResource FontMono}" FontSize="11"
                                           Foreground="{StaticResource Blue400}" HorizontalAlignment="Center"/>
                                <Rectangle Height="1" Width="40" Fill="#4060A5FA" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>
                        <Rectangle Width="2"  Height="18" Fill="#4060A5FA" HorizontalAlignment="Center"/>
                        <Rectangle Width="50" Height="8" Fill="#4060A5FA" RadiusX="1" RadiusY="1"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="32,22,32,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="CAPTURE" Style="{StaticResource Eyebrow}"/>
                    <Border Grid.Row="0" Grid.Column="1" Background="#1434D399" CornerRadius="999"
                            Padding="10,4" VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="{StaticResource Success}"
                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="ready" Foreground="{StaticResource Success}"
                                       FontFamily="{StaticResource FontMono}" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                VerticalAlignment="Center" Margin="0,16,0,0">
                        <TextBlock Text="Capture Card"
                                   FontFamily="{StaticResource FontDisplay}" FontSize="44"
                                   FontWeight="Bold" Foreground="{StaticResource Text}" LineHeight="42"/>
                        <TextBlock Text="USB / HDMI capture card · DirectShow · OBS virtual camera"
                                   Style="{StaticResource Body}"
                                   Foreground="{StaticResource TextMuted}" Margin="0,8,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="any console" Style="{StaticResource Caption}" FontFamily="{StaticResource FontMono}"/>
                            <Border Width="1" Height="12" Background="{StaticResource BorderBright}" Margin="10,0"/>
                            <TextBlock Text="external hardware" Style="{StaticResource Caption}" FontFamily="{StaticResource FontMono}"/>
                            <Border Width="1" Height="12" Background="{StaticResource BorderBright}" Margin="10,0"/>
                            <TextBlock Text="up to 4k60" Style="{StaticResource Caption}" FontFamily="{StaticResource FontMono}"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="White" CornerRadius="2" Padding="28,10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="START" Foreground="Black"
                                           FontFamily="{StaticResource FontDisplay}"
                                           FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="  →" Foreground="Black"
                                           FontFamily="{StaticResource FontDisplay}"
                                           FontWeight="Bold" FontSize="14"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
        </Button>

        <!-- ============ Secondary row · PS (READY), Xbox, Cloud ============ -->
        <Grid Grid.Row="2" Margin="32,14,32,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- PS Remote Play — READY (only clickable card in this row) -->
            <Button Grid.Column="0" Click="PsRp_Click" Cursor="Hand" BorderThickness="0" Padding="0"
                    Margin="0,0,4,0" HorizontalContentAlignment="Stretch">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{StaticResource Surface}"
                                BorderBrush="{StaticResource Blue400}" BorderThickness="1"
                                CornerRadius="2" Padding="14,12">
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="READY" Style="{StaticResource Eyebrow}"/>
                                    <Ellipse Width="6" Height="6" Fill="{StaticResource Success}"
                                             DockPanel.Dock="Right" VerticalAlignment="Center"/>
                                </DockPanel>
                                <TextBlock Text="PS Remote Play" FontFamily="{StaticResource FontDisplay}"
                                           FontSize="16" FontWeight="SemiBold" Margin="0,6,0,0"/>
                                <TextBlock Text="PS5 via labs engine · LAN / PSN"
                                           Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                                <TextBlock Text="start →" FontFamily="{StaticResource FontDisplay}" FontSize="12"
                                           FontWeight="SemiBold" Foreground="{StaticResource Blue400}"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{StaticResource SurfaceHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="1" Click="XboxRp_Click" Cursor="Hand" BorderThickness="0" Padding="0"
                    Margin="4,0" HorizontalContentAlignment="Stretch">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="B" Background="{StaticResource Surface}"
                          BorderBrush="{StaticResource Blue400}" BorderThickness="1"
                          CornerRadius="2" Padding="14,12">
                    <ContentPresenter/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="B" Property="Background" Value="{StaticResource SurfaceHover}"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
              <StackPanel>
                <DockPanel LastChildFill="False">
                  <TextBlock Text="READY" Style="{StaticResource Eyebrow}"/>
                  <Ellipse Width="6" Height="6" Fill="{StaticResource Success}"
                           DockPanel.Dock="Right" VerticalAlignment="Center"/>
                </DockPanel>
                <TextBlock Text="Xbox Remote Play" FontFamily="{StaticResource FontDisplay}"
                           FontSize="16" FontWeight="SemiBold" Margin="0,6,0,0"/>
                <TextBlock Text="Xbox console · Xbox account" Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                <TextBlock Text="start →" FontFamily="{StaticResource FontDisplay}" FontSize="12"
                           FontWeight="SemiBold" Foreground="{StaticResource Blue400}" Margin="0,10,0,0"/>
              </StackPanel>
            </Button>

            <Button Grid.Column="2" Click="Cloud_Click" Cursor="Hand" BorderThickness="0" Padding="0"
                    Margin="4,0,0,0" HorizontalContentAlignment="Stretch">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border x:Name="B" Background="{StaticResource Surface}"
                          BorderBrush="{StaticResource Blue400}" BorderThickness="1"
                          CornerRadius="2" Padding="14,12">
                    <ContentPresenter/>
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter TargetName="B" Property="Background" Value="{StaticResource SurfaceHover}"/>
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
              <StackPanel>
                <DockPanel LastChildFill="False">
                  <TextBlock Text="READY" Style="{StaticResource Eyebrow}"/>
                  <Ellipse Width="6" Height="6" Fill="{StaticResource Success}"
                           DockPanel.Dock="Right" VerticalAlignment="Center"/>
                </DockPanel>
                <TextBlock Text="Cloud Gaming" FontFamily="{StaticResource FontDisplay}"
                           FontSize="16" FontWeight="SemiBold" Margin="0,6,0,0"/>
                <TextBlock Text="xCloud · in-browser · MS account" Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                <TextBlock Text="start →" FontFamily="{StaticResource FontDisplay}" FontSize="12"
                           FontWeight="SemiBold" Foreground="{StaticResource Blue400}" Margin="0,10,0,0"/>
              </StackPanel>
            </Button>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="32,14,32,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="one entry · any source"
                       Style="{StaticResource Caption}" FontFamily="{StaticResource FontMono}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="cancel" Style="{StaticResource BtnGhost}" Click="Cancel_Click"/>
        </Grid>
    </Grid>
</Window>
