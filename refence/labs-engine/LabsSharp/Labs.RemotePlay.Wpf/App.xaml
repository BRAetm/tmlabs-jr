<Application x:Class="Labs.RemotePlay.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>

            <!-- =========================================================
                 LABS DESIGN SYSTEM · Deep Blue / Dark Slate
                 Palette sourced from UI/UX Pro Max (Ride Hailing +
                 Personal Finance categories), tuned for a gaming shell.
                 ========================================================= -->

            <!-- Surfaces -->
            <SolidColorBrush x:Key="Bg"           Color="#070A14"/>
            <SolidColorBrush x:Key="BgSubtle"     Color="#0B1020"/>
            <SolidColorBrush x:Key="Surface"      Color="#11182C"/>
            <SolidColorBrush x:Key="SurfaceHover" Color="#182142"/>
            <SolidColorBrush x:Key="Overlay"      Color="#0B1020" Opacity="0.85"/>

            <!-- Borders (low-key; never compete with content) -->
            <SolidColorBrush x:Key="BorderSoft"   Color="#1E2A4A"/>
            <SolidColorBrush x:Key="BorderBright" Color="#2E3F6A"/>

            <!-- Blue scale -->
            <SolidColorBrush x:Key="Blue50"       Color="#EFF6FF"/>
            <SolidColorBrush x:Key="Blue200"      Color="#BFDBFE"/>
            <SolidColorBrush x:Key="Blue400"      Color="#60A5FA"/>
            <SolidColorBrush x:Key="Blue500"      Color="#3B82F6"/>
            <SolidColorBrush x:Key="Blue600"      Color="#2563EB"/>
            <SolidColorBrush x:Key="Blue700"      Color="#1D4ED8"/>

            <!-- Semantic -->
            <SolidColorBrush x:Key="Accent"       Color="#3B82F6"/>
            <SolidColorBrush x:Key="AccentHover"  Color="#2563EB"/>
            <SolidColorBrush x:Key="Glow"         Color="#60A5FA"/>
            <SolidColorBrush x:Key="Danger"       Color="#F87171"/>
            <SolidColorBrush x:Key="Success"      Color="#34D399"/>

            <!-- Text -->
            <SolidColorBrush x:Key="Text"         Color="#F1F5F9"/>
            <SolidColorBrush x:Key="TextMuted"    Color="#94A3B8"/>
            <SolidColorBrush x:Key="TextDim"      Color="#64748B"/>

            <!-- Accent linear brushes for hero panels -->
            <LinearGradientBrush x:Key="HeroGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1D4ED8" Offset="0"/>
                <GradientStop Color="#0B1430" Offset="0.55"/>
                <GradientStop Color="#050812" Offset="1"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="AccentLine" StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#3B82F6" Offset="0"/>
                <GradientStop Color="#60A5FA" Offset="0.5"/>
                <GradientStop Color="#3B82F6" Offset="1"/>
            </LinearGradientBrush>

            <!-- Typography -->
            <FontFamily x:Key="FontDisplay">Segoe UI Variable Display, Segoe UI, Arial</FontFamily>
            <FontFamily x:Key="FontBody">Segoe UI Variable Text, Segoe UI, Arial</FontFamily>
            <FontFamily x:Key="FontMono">Cascadia Mono, Consolas, Courier New</FontFamily>

            <!-- ============== Typographic scale ============== -->
            <Style x:Key="H1" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontDisplay}"/>
                <Setter Property="FontSize" Value="56"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="{StaticResource Text}"/>
                <Setter Property="LineHeight" Value="56"/>
            </Style>
            <Style x:Key="H2" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontDisplay}"/>
                <Setter Property="FontSize" Value="28"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource Text}"/>
            </Style>
            <Style x:Key="H3" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontDisplay}"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource Text}"/>
            </Style>
            <Style x:Key="Body" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{StaticResource Text}"/>
            </Style>
            <Style x:Key="Caption" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            </Style>
            <Style x:Key="Eyebrow" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Foreground" Value="{StaticResource Blue400}"/>
            </Style>

            <!-- ============== Buttons ============== -->

            <Style x:Key="BtnPrimary" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource Accent}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="#00000000"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="22,10"/>
                <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="2"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHover}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="BtnGhost" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
                <Setter Property="Background" Value="#00000000"/>
                <Setter Property="Foreground" Value="{StaticResource Text}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource BorderBright}" BorderThickness="1"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceHover}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="BtnQuiet" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
                <Setter Property="Background" Value="#00000000"/>
                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="FontWeight" Value="Normal"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- TextBox -->
            <Style TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource Surface}"/>
                <Setter Property="Foreground" Value="{StaticResource Text}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontFamily" Value="{StaticResource FontBody}"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="CaretBrush" Value="{StaticResource Blue400}"/>
                <Setter Property="SelectionBrush" Value="{StaticResource Blue600}"/>
            </Style>
            <Style TargetType="ComboBox">
                <Setter Property="Background" Value="{StaticResource Surface}"/>
                <Setter Property="Foreground" Value="{StaticResource Text}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,8"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
