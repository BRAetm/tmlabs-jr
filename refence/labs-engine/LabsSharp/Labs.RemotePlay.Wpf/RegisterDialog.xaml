<Window x:Class="Labs.RemotePlay.RegisterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Register PS5" Height="380" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource Bg}" Foreground="{StaticResource Text}"
        FontFamily="Segoe UI" FontSize="14">
    <StackPanel Margin="24">
        <TextBlock Name="HostHeader" Text="Register with console" FontSize="18" FontWeight="SemiBold"/>
        <TextBlock Text="On your PS5: Settings → System → Remote Play → Link Device. Enter the 8-digit PIN below."
                   Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,8,0,16"/>

        <TextBlock Text="PIN" Margin="0,8,0,4"/>
        <TextBox Name="PinBox" MaxLength="8" Padding="8" FontSize="20"
                 Background="{StaticResource Surface}" Foreground="{StaticResource Text}" BorderThickness="0"/>

        <TextBlock Name="ErrorText" Foreground="#F87171" Margin="0,12,0,0" TextWrapping="Wrap"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button Content="Cancel" Click="Cancel_Click" Padding="16,8" Margin="0,0,8,0"
                    Background="{StaticResource Surface}" Foreground="{StaticResource Text}" BorderThickness="0"/>
            <Button Name="OkButton" Content="Register" Click="Ok_Click" Padding="16,8"
                    Background="{StaticResource Accent}" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </StackPanel>
</Window>
