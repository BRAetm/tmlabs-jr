<UserControl x:Class="Labs.RemotePlay.Panels.SessionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Bg}">
    <Grid>
        <!-- ========= PICKER ========= -->
        <Grid Name="PickerPanel" Visibility="Visible" Margin="28,22,28,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0" Text="PS Remote Play" FontFamily="{StaticResource FontDisplay}"
                       FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource Text}"/>

            <!-- PSN Account Bar — big and visible -->
            <Border Grid.Row="1" Background="{StaticResource Surface}" CornerRadius="4"
                    Padding="16,12" Margin="0,16,0,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Name="PsnSignInButton" Content="Sign in with PSN" Style="{StaticResource BtnPrimary}"
                                Padding="18,8" Click="PsnSignIn_Click"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="PSN Account" FontWeight="SemiBold" Foreground="{StaticResource Text}" FontSize="13"/>
                        <TextBlock Name="AccountStatus" Text="not signed in — sign in to connect"
                                   Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Status + Rescan -->
            <DockPanel Grid.Row="2" Margin="0,16,0,0">
                <Button Content="rescan" DockPanel.Dock="Right" Style="{StaticResource BtnGhost}"
                        Padding="14,6" Click="Rescan_Click"/>
                <TextBlock Name="StatusBox" Text="searching the LAN…"
                           Style="{StaticResource Caption}" FontFamily="{StaticResource FontMono}"
                           VerticalAlignment="Center"/>
            </DockPanel>

            <!-- Console list -->
            <ListBox Grid.Row="3" Name="HostList" Background="Transparent" BorderThickness="0"
                     Foreground="{StaticResource Text}" Padding="0,8,0,0"
                     SelectionChanged="HostList_SelectionChanged"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,4"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource Text}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,0,0,1"
                                            Padding="6,14">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#0A1020"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceHover}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="6" Height="6" Fill="#34D399" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#F1F5F9" FontSize="14"/>
                                <TextBlock Foreground="#94A3B8" FontSize="12" Margin="0,1,0,0">
                                    <Run Text="{Binding Address}"/>
                                    <Run Text="  ·  "/>
                                    <Run Text="{Binding Status}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Empty state -->
            <StackPanel Grid.Row="3" Name="EmptyHint" HorizontalAlignment="Center" VerticalAlignment="Center"
                        IsHitTestVisible="False">
                <TextBlock Text="no consoles found — make sure your PS5 is on the same network"
                           Style="{StaticResource Caption}" FontFamily="{StaticResource FontMono}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Bottom bar — selected console + actions -->
            <Border Grid.Row="4" Background="{StaticResource Surface}" CornerRadius="4"
                    Padding="16,12" Margin="0,12,0,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Name="RegisterButton" Content="Register Console" Style="{StaticResource BtnGhost}"
                                IsEnabled="False" Padding="16,8" Margin="0,0,8,0" Click="Register_Click"/>
                        <Button Name="ConnectButton" Content="Connect" Style="{StaticResource BtnPrimary}"
                                IsEnabled="False" Padding="20,8" Click="Connect_Click"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Name="SelectedName" Text="select a console above"
                                   FontFamily="{StaticResource FontDisplay}" FontSize="14"
                                   FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                        <TextBlock Name="SelectedDetail" Text=""
                                   Style="{StaticResource Caption}" FontFamily="{StaticResource FontMono}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ========= STREAMING ========= -->
        <Grid Name="StreamPanel" Visibility="Collapsed" Background="Black">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Grid.RowSpan="2">
                <Image Name="VideoSurface" Stretch="Uniform"/>
                <TextBlock Name="StreamOverlay" Text="connecting…" Foreground="White"
                           FontFamily="{StaticResource FontDisplay}" FontSize="16"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Border Background="#80000000" VerticalAlignment="Top" Padding="12,6">
                    <DockPanel LastChildFill="False">
                        <TextBlock Name="StreamHud" Foreground="#B0FFFFFF" FontSize="11"
                                   FontFamily="{StaticResource FontMono}" VerticalAlignment="Center"/>
                        <Button Content="stop" DockPanel.Dock="Right" Style="{StaticResource BtnQuiet}" Click="Stop_Click"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
