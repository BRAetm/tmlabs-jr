<UserControl x:Class="Labs.RemotePlay.Panels.XboxRpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Bg}">
    <Grid>
        <!-- Picker (no window selected yet) -->
        <Grid Name="PickerPanel" Visibility="Visible" Margin="28,22,28,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="xbox remote play" FontFamily="{StaticResource FontDisplay}"
                           FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource Text}"/>
                <TextBlock Name="StatusBox" Text="scanning for Xbox app…"
                           FontFamily="{StaticResource FontMono}" FontSize="12"
                           Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                <TextBlock Text="open the Xbox app and start Remote Play from your console, then pick the window below."
                           FontFamily="{StaticResource FontBody}" FontSize="12"
                           Foreground="{StaticResource TextDim}" TextWrapping="Wrap" Margin="0,8,0,0"/>
            </StackPanel>

            <Border Grid.Row="1" Margin="0,16,0,0" Height="1" Background="{StaticResource BorderSoft}" VerticalAlignment="Top"/>

            <ListBox Grid.Row="1" Name="WindowList" Background="Transparent" BorderThickness="0"
                     Margin="0,18,0,0" Foreground="{StaticResource Text}"
                     SelectionChanged="WindowList_SelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="6,12"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            BorderBrush="{StaticResource BorderSoft}" BorderThickness="0,0,0,1"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#0A1020"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceHover}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="#34D399" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="#F1F5F9"/>
                                <TextBlock Foreground="#94A3B8" FontSize="11">
                                    <Run Text="{Binding ProcessName}"/><Run Text=" · PID "/><Run Text="{Binding Pid}"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Name="EmptyHint" Grid.Row="1" Margin="0,24,0,0"
                       Text="no Xbox windows found — make sure the Xbox app is running"
                       FontFamily="{StaticResource FontMono}" FontSize="11"
                       Foreground="{StaticResource TextDim}" VerticalAlignment="Top"
                       HorizontalAlignment="Center"/>

            <Grid Grid.Row="2" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="rescan" Style="{StaticResource BtnGhost}" Click="Rescan_Click"/>
                <Button Grid.Column="2" Name="StartButton" Content="start capture →" Style="{StaticResource BtnPrimary}"
                        IsEnabled="False" Click="Start_Click"/>
            </Grid>
        </Grid>

        <!-- Live feed -->
        <Grid Name="StreamPanel" Visibility="Collapsed" Background="Black">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Image Grid.Row="0" Name="VideoSurface" Stretch="Uniform"/>
            <Border Grid.Row="1" Background="#80000000" Padding="12,6">
                <DockPanel LastChildFill="False">
                    <TextBlock Name="StreamHud" Foreground="#B0FFFFFF" FontSize="11"
                               FontFamily="{StaticResource FontMono}" VerticalAlignment="Center"/>
                    <Button Content="stop" DockPanel.Dock="Right" Style="{StaticResource BtnQuiet}" Click="Stop_Click"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
