<UserControl x:Class="Labs.RemotePlay.Panels.ControllerMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <SolidColorBrush x:Key="MonSurface" Color="#1b1b1f"/>
        <SolidColorBrush x:Key="MonBorder"  Color="#3a3a40"/>
        <SolidColorBrush x:Key="MonOn"      Color="#58d17a"/>
        <SolidColorBrush x:Key="MonDim"     Color="#7a7a80"/>
        <Style x:Key="Led" TargetType="Ellipse">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Fill" Value="{StaticResource MonSurface}"/>
            <Setter Property="Stroke" Value="{StaticResource MonBorder}"/>
            <Setter Property="StrokeThickness" Value="1"/>
        </Style>
        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource MonDim}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Width="14" Height="64" VerticalAlignment="Center">
                <Border Background="{StaticResource MonSurface}" BorderBrush="{StaticResource MonBorder}" BorderThickness="1" CornerRadius="2"/>
                <Rectangle x:Name="L2Bar" Fill="{StaticResource MonOn}" VerticalAlignment="Bottom" Height="0" Margin="1"/>
            </Grid>

            <Grid Grid.Column="1" Width="68" Height="68" HorizontalAlignment="Center">
                <Ellipse Fill="{StaticResource MonSurface}" Stroke="{StaticResource MonBorder}" StrokeThickness="1"/>
                <Canvas x:Name="LeftStickCanvas" Width="68" Height="68">
                    <Ellipse x:Name="LeftStickDot" Width="12" Height="12" Fill="{StaticResource MonOn}"
                             Canvas.Left="28" Canvas.Top="28"/>
                </Canvas>
            </Grid>

            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="6,0">
                <TextBlock Text="LS" Style="{StaticResource Caption}"/>
                <TextBlock Text=" / " Style="{StaticResource Caption}"/>
                <TextBlock Text="RS" Style="{StaticResource Caption}"/>
            </StackPanel>

            <Grid Grid.Column="3" Width="68" Height="68" HorizontalAlignment="Center">
                <Ellipse Fill="{StaticResource MonSurface}" Stroke="{StaticResource MonBorder}" StrokeThickness="1"/>
                <Canvas x:Name="RightStickCanvas" Width="68" Height="68">
                    <Ellipse x:Name="RightStickDot" Width="12" Height="12" Fill="{StaticResource MonOn}"
                             Canvas.Left="28" Canvas.Top="28"/>
                </Canvas>
            </Grid>

            <Grid Grid.Column="4" Width="14" Height="64" VerticalAlignment="Center">
                <Border Background="{StaticResource MonSurface}" BorderBrush="{StaticResource MonBorder}" BorderThickness="1" CornerRadius="2"/>
                <Rectangle x:Name="R2Bar" Fill="{StaticResource MonOn}" VerticalAlignment="Bottom" Height="0" Margin="1"/>
            </Grid>
        </Grid>

        <Grid Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center">
                <Ellipse x:Name="LedA" Style="{StaticResource Led}"/>
                <TextBlock Text="A" Style="{StaticResource Caption}"/>
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center">
                <Ellipse x:Name="LedB" Style="{StaticResource Led}"/>
                <TextBlock Text="B" Style="{StaticResource Caption}"/>
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center">
                <Ellipse x:Name="LedX" Style="{StaticResource Led}"/>
                <TextBlock Text="X" Style="{StaticResource Caption}"/>
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="3" HorizontalAlignment="Center">
                <Ellipse x:Name="LedY" Style="{StaticResource Led}"/>
                <TextBlock Text="Y" Style="{StaticResource Caption}"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center">
                <Ellipse x:Name="LedLB" Style="{StaticResource Led}"/>
                <TextBlock Text="LB" Style="{StaticResource Caption}"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center">
                <Ellipse x:Name="LedRB" Style="{StaticResource Led}"/>
                <TextBlock Text="RB" Style="{StaticResource Caption}"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center">
                <Ellipse x:Name="LedBack" Style="{StaticResource Led}"/>
                <TextBlock Text="Back" Style="{StaticResource Caption}"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="3" HorizontalAlignment="Center">
                <Ellipse x:Name="LedStart" Style="{StaticResource Led}"/>
                <TextBlock Text="Start" Style="{StaticResource Caption}"/>
            </StackPanel>
        </Grid>

        <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                <Ellipse x:Name="LedDUp" Style="{StaticResource Led}"/>
                <TextBlock Text="Up" Style="{StaticResource Caption}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                <Ellipse x:Name="LedDDown" Style="{StaticResource Led}"/>
                <TextBlock Text="Dn" Style="{StaticResource Caption}"/>
            </StackPanel>
            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                <Ellipse x:Name="LedDLeft" Style="{StaticResource Led}"/>
                <TextBlock Text="Lf" Style="{StaticResource Caption}"/>
            </StackPanel>
            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                <Ellipse x:Name="LedDRight" Style="{StaticResource Led}"/>
                <TextBlock Text="Rt" Style="{StaticResource Caption}"/>
            </StackPanel>
        </Grid>

        <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                <Ellipse x:Name="LedL3" Style="{StaticResource Led}"/>
                <TextBlock Text="L3" Style="{StaticResource Caption}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                <Ellipse x:Name="LedGuide" Style="{StaticResource Led}"/>
                <TextBlock Text="Guide" Style="{StaticResource Caption}"/>
            </StackPanel>
            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                <Ellipse x:Name="LedR3" Style="{StaticResource Led}"/>
                <TextBlock Text="R3" Style="{StaticResource Caption}"/>
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
