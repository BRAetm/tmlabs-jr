<Window x:Class="Labs.RemotePlay.ConsolePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="labs engine · ps remote play" Height="760" Width="1180"
        Background="{DynamicResource Bg}" Foreground="{DynamicResource Text}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        UseLayoutRounding="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <DockPanel LastChildFill="True">
        <!-- Branded caption bar -->
        <Grid DockPanel.Dock="Top" Height="40" Background="{DynamicResource BgSubtle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                <Canvas Width="18" Height="18" VerticalAlignment="Center">
                    <Path Fill="{DynamicResource Accent}"
                          Data="M 2,2 L 8,2 L 8,12 L 16,12 L 16,16 L 2,16 Z"/>
                    <Ellipse Canvas.Left="11" Canvas.Top="3" Width="3" Height="3" Fill="{StaticResource Blue400}"/>
                </Canvas>
                <TextBlock Text="labs engine" Margin="10,0,0,0" VerticalAlignment="Center"
                           FontFamily="{StaticResource FontDisplay}" FontSize="12"
                           FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                <TextBlock Text="/ ps remote play" Margin="8,0,0,0" VerticalAlignment="Center"
                           FontFamily="{StaticResource FontMono}" FontSize="10"
                           Foreground="{StaticResource TextMuted}"/>
            </StackPanel>
            <Button Grid.Column="1" Style="{StaticResource CaptionCloseBtn}"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="CaptionClose_Click"/>
        </Grid>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT RAIL -->
        <Grid Grid.Column="0" Background="{DynamicResource BgSubtle}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Margin="28,32,28,24">
                <TextBlock Text="/ PS REMOTE PLAY" Style="{StaticResource Eyebrow}"/>
                <TextBlock Text="consoles" Style="{StaticResource H2}" Margin="0,6,0,0"/>
                <Border Height="2" Width="40" HorizontalAlignment="Left" Margin="0,10,0,0"
                        Background="{StaticResource AccentLine}"/>
            </StackPanel>

            <!-- PSN account block -->
            <Border Grid.Row="1" Margin="20,0,20,16" Padding="16,14"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="2">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="PSN" Style="{StaticResource Eyebrow}"/>
                        <TextBlock Name="AccountStatus" Text="not signed in"
                                   Margin="0,6,0,0" Foreground="{StaticResource TextMuted}" FontSize="13"/>
                    </StackPanel>
                    <Button Name="PsnSignInButton" Content="sign in" Style="{StaticResource BtnPrimary}"
                            Margin="0,12,0,0" HorizontalAlignment="Left" Click="PsnSignIn_Click"/>
                </DockPanel>
            </Border>

            <ListBox Grid.Row="2" Name="HostList" Background="Transparent" BorderThickness="0"
                     Foreground="{DynamicResource Text}" Padding="12,0,12,12"
                     SelectionChanged="HostList_SelectionChanged"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="12,12"/>
                        <Setter Property="Margin" Value="0,4"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
                        <Setter Property="Foreground" Value="{DynamicResource Text}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="2" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SurfaceHover}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource Blue400}"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                                <Condition Property="IsSelected" Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter Property="Background" Value="{DynamicResource Surface}"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="#1D4ED8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#F1F5F9"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Address}" Foreground="#94A3B8" FontSize="12" Margin="14,2,0,0"/>
                            <TextBlock Text="{Binding Status}" Foreground="#64748B" FontSize="11" Margin="14,1,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="3" Margin="28,0,28,24">
                <Button Name="SettingsButton" Content="settings" Style="{StaticResource BtnQuiet}"
                        HorizontalAlignment="Left" Click="SettingsButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- MAIN STAGE -->
        <Grid Grid.Column="1" Margin="48,40,48,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="SELECTED" Style="{StaticResource Eyebrow}"/>
                <TextBlock Name="SelectedName" Text="no console selected"
                           Style="{StaticResource H1}" FontSize="44" Margin="0,6,0,0"/>
                <TextBlock Name="SelectedStatus" Text="pick one on the left · or wait for discovery"
                           Style="{StaticResource Body}" Foreground="{StaticResource TextMuted}"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Detail card -->
            <Border Grid.Row="1" Margin="0,28,0,0" Background="{StaticResource HeroGradient}"
                    CornerRadius="3" ClipToBounds="True">
                <Grid>
                    <Rectangle HorizontalAlignment="Stretch" VerticalAlignment="Top"
                               Height="2" Fill="{StaticResource AccentLine}"/>
                    <Ellipse HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Width="500" Height="500" Margin="0,0,-160,-160" Opacity="0.25">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#3B82F6" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <Grid Margin="40,32">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="LAN STATUS" Style="{StaticResource Eyebrow}"/>
                            <TextBlock Name="StatusBox" Text="searching for consoles on the network…"
                                       Style="{StaticResource Body}" Foreground="{StaticResource TextMuted}"
                                       Margin="0,10,0,0"/>
                        </StackPanel>

                        <!-- stream spec strip -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="1080p · 60fps" Style="{StaticResource Caption}"
                                           FontFamily="{StaticResource FontMono}"/>
                                <Border Width="1" Height="12" Background="{StaticResource BorderBright}" Margin="12,0"/>
                                <TextBlock Text="H.264" Style="{StaticResource Caption}"
                                           FontFamily="{StaticResource FontMono}"/>
                                <Border Width="1" Height="12" Background="{StaticResource BorderBright}" Margin="12,0"/>
                                <TextBlock Text="15 mbps" Style="{StaticResource Caption}"
                                           FontFamily="{StaticResource FontMono}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Name="RegisterButton" Content="register" Style="{StaticResource BtnGhost}"
                                        Margin="0,0,10,0" IsEnabled="False" Click="RegisterButton_Click"/>
                                <Button Name="ConnectButton" Content="connect →" Style="{StaticResource BtnPrimary}"
                                        IsEnabled="False" Click="ConnectButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- footnote -->
            <TextBlock Grid.Row="2" Text="UDP/9302 · discovery broadcast every 2s"
                       Style="{StaticResource Caption}"
                       FontFamily="{StaticResource FontMono}" Margin="0,14,0,0"/>
        </Grid>
    </Grid>
    </DockPanel>
</Window>
