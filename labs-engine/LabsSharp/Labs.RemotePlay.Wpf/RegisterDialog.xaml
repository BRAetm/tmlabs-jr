<Window x:Class="Labs.RemotePlay.RegisterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="register ps5" Height="420" Width="440"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None"
        Background="{DynamicResource Bg}" Foreground="{DynamicResource Text}"
        FontFamily="Segoe UI" FontSize="14">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="0"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <DockPanel LastChildFill="True">
        <!-- Branded caption bar -->
        <Grid DockPanel.Dock="Top" Height="40" Background="{DynamicResource BgSubtle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                <Canvas Width="18" Height="18" VerticalAlignment="Center">
                    <Path Fill="{DynamicResource Accent}"
                          Data="M 2,2 L 8,2 L 8,12 L 16,12 L 16,16 L 2,16 Z"/>
                    <Ellipse Canvas.Left="11" Canvas.Top="3" Width="3" Height="3" Fill="{StaticResource Blue400}"/>
                </Canvas>
                <TextBlock Text="labs engine" Margin="10,0,0,0" VerticalAlignment="Center"
                           FontFamily="{StaticResource FontDisplay}" FontSize="12"
                           FontWeight="SemiBold" Foreground="{DynamicResource Text}"/>
                <TextBlock Text="/ register ps5" Margin="8,0,0,0" VerticalAlignment="Center"
                           FontFamily="{StaticResource FontMono}" FontSize="10"
                           Foreground="{StaticResource TextMuted}"/>
            </StackPanel>
            <Button Grid.Column="1" Style="{StaticResource CaptionCloseBtn}"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="Cancel_Click"/>
        </Grid>
    <StackPanel Margin="24">
        <TextBlock Name="HostHeader" Text="Register with console" FontSize="18" FontWeight="SemiBold"/>
        <TextBlock Text="On your PS5: Settings → System → Remote Play → Link Device. Enter the 8-digit PIN below."
                   Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,8,0,16"/>

        <TextBlock Text="PIN" Margin="0,8,0,4"/>
        <TextBox Name="PinBox" MaxLength="8" Padding="8" FontSize="20"
                 Background="{DynamicResource Surface}" Foreground="{DynamicResource Text}" BorderThickness="0"/>

        <TextBlock Name="ErrorText" Foreground="#F87171" Margin="0,12,0,0" TextWrapping="Wrap"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button Content="Cancel" Click="Cancel_Click" Padding="16,8" Margin="0,0,8,0"
                    Background="{DynamicResource Surface}" Foreground="{DynamicResource Text}" BorderThickness="0"/>
            <Button Name="OkButton" Content="Register" Click="Ok_Click" Padding="16,8"
                    Background="{DynamicResource Accent}" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </StackPanel>
    </DockPanel>
</Window>
