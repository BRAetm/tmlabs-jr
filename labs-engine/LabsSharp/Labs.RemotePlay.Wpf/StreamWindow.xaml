<Window x:Class="Labs.RemotePlay.StreamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="labs engine · streaming" Height="740" Width="1280"
        Background="Black" Foreground="White"
        FontFamily="Segoe UI" FontSize="14"
        WindowStyle="None"
        WindowState="Normal">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="6"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Minimal caption overlay so stream-area stays maximal -->
        <Grid Grid.Row="0" Background="#E0000000">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                <Canvas Width="16" Height="16" VerticalAlignment="Center">
                    <Path Fill="#3B82F6" Data="M 2,2 L 7,2 L 7,10 L 14,10 L 14,14 L 2,14 Z"/>
                    <Ellipse Canvas.Left="10" Canvas.Top="3" Width="3" Height="3" Fill="#60A5FA"/>
                </Canvas>
                <TextBlock Text="labs engine · streaming" Margin="10,0,0,0" VerticalAlignment="Center"
                           FontFamily="Cascadia Mono, Consolas" FontSize="11" Foreground="#B0FFFFFF"/>
            </StackPanel>
            <Button Grid.Column="1" Content="✕" Width="44" Height="36"
                    Background="Transparent" Foreground="#B0FFFFFF" BorderThickness="0"
                    FontFamily="Cascadia Mono, Consolas" FontSize="12" Cursor="Hand"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="CaptionClose_Click"/>
        </Grid>

        <Grid Grid.Row="1">
            <Image Name="VideoSurface" Stretch="Uniform"/>
            <TextBlock Name="Overlay" Text="connecting…" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24"/>
            <TextBlock Name="Hud" Foreground="#80FFFFFF" FontSize="11"
                       HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12"/>
        </Grid>
    </Grid>
</Window>
