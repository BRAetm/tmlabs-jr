<UserControl x:Class="Labs.RemotePlay.Panels.CaptureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Bg}">
    <Grid>
        <!-- Picker (no device selected yet) -->
        <Grid Name="PickerPanel" Visibility="Visible" Margin="40,32,40,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: eyebrow + heading + live status pill -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="NEW SESSION · CAPTURE CARD" Style="{StaticResource Eyebrow}"/>
                    <TextBlock Text="select a source" Style="{StaticResource H2}" Margin="0,6,0,0"/>
                </StackPanel>

                <Border Grid.Column="1" VerticalAlignment="Center"
                        Background="{DynamicResource Surface}"
                        BorderBrush="{StaticResource BorderSoft}" BorderThickness="1"
                        CornerRadius="2" Padding="12,6">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Fill="{DynamicResource Accent}" VerticalAlignment="Center"/>
                        <TextBlock Name="StatusBox" Text="scanning…"
                                   Margin="8,0,0,0" FontFamily="{StaticResource FontMono}"
                                   FontSize="11" Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Rectangle Grid.Row="1" Height="1" Fill="{StaticResource BorderSoft}" Margin="0,22,0,0"/>

            <!-- Device cards -->
            <ListBox Grid.Row="2" Name="DeviceList" Margin="0,24,0,0"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionChanged="DeviceList_SelectionChanged">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,12,12"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{DynamicResource Surface}"
                                            BorderBrush="{StaticResource BorderSoft}" BorderThickness="1"
                                            CornerRadius="3" Padding="18,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Icon: camera lens glyph -->
                                            <Border Grid.Column="0" Width="42" Height="42" CornerRadius="2"
                                                    Background="{DynamicResource BgSubtle}"
                                                    BorderBrush="{StaticResource BorderSoft}" BorderThickness="1"
                                                    VerticalAlignment="Center">
                                                <Grid>
                                                    <Ellipse Width="20" Height="20"
                                                             Stroke="{StaticResource Blue400}" StrokeThickness="1.5"
                                                             Fill="{x:Null}"/>
                                                    <Ellipse Width="8" Height="8" Fill="{DynamicResource Accent}"/>
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,12,0">
                                                <ContentPresenter/>
                                            </StackPanel>

                                            <!-- Selected arrow -->
                                            <TextBlock x:Name="SelMark" Grid.Column="2" Text="→"
                                                       FontFamily="{StaticResource FontDisplay}" FontSize="18"
                                                       Foreground="{DynamicResource Accent}"
                                                       VerticalAlignment="Center" Opacity="0"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceHover}"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderBright}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceHover}"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                            <Setter TargetName="SelMark" Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Name}"
                                       FontFamily="{StaticResource FontDisplay}" FontSize="14"
                                       FontWeight="SemiBold" Foreground="{DynamicResource Text}"
                                       TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock FontFamily="{StaticResource FontMono}" FontSize="11"
                                           Foreground="{StaticResource Blue400}">
                                    <Run Text="#"/><Run Text="{Binding Index}"/>
                                </TextBlock>
                                <TextBlock FontFamily="{StaticResource FontMono}" FontSize="11"
                                           Foreground="{StaticResource TextMuted}" Margin="10,0,0,0">
                                    <Run Text="·"/>
                                    <Run Text="{Binding Width}"/><Run Text="×"/><Run Text="{Binding Height}"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Settings + actions -->
            <Border Grid.Row="3" Background="{DynamicResource BgSubtle}"
                    BorderBrush="{StaticResource BorderSoft}" BorderThickness="1"
                    CornerRadius="3" Padding="20,16" Margin="0,20,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="RESOLUTION" Style="{StaticResource Eyebrow}"/>
                        <ComboBox Name="ResolutionCombo" Width="200" Margin="0,6,0,0" SelectedIndex="0">
                            <ComboBoxItem Tag="0x0"       Content="auto (device native)"/>
                            <ComboBoxItem Tag="1920x1080" Content="1920 × 1080"/>
                            <ComboBoxItem Tag="1280x720"  Content="1280 × 720"/>
                            <ComboBoxItem Tag="2560x1440" Content="2560 × 1440"/>
                            <ComboBoxItem Tag="3840x2160" Content="3840 × 2160"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="FPS" Style="{StaticResource Eyebrow}"/>
                        <ComboBox Name="FpsCombo" Width="96" Margin="0,6,0,0" SelectedIndex="1">
                            <ComboBoxItem Tag="30"  Content="30"/>
                            <ComboBoxItem Tag="60"  Content="60"/>
                            <ComboBoxItem Tag="120" Content="120"/>
                        </ComboBox>
                    </StackPanel>

                    <Button Grid.Column="4" Content="rescan" Style="{StaticResource BtnGhost}"
                            Click="Rescan_Click" VerticalAlignment="Bottom"/>
                    <Button Grid.Column="6" Name="StartButton"
                            Content="start capture →" Style="{StaticResource BtnPrimary}"
                            IsEnabled="False" Click="Start_Click" VerticalAlignment="Bottom"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Live feed -->
        <Grid Name="StreamPanel" Visibility="Collapsed" Background="Black">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Image Grid.Row="0" Grid.RowSpan="2" Name="VideoSurface" Stretch="Uniform"/>
            <Border Grid.Row="2" Background="#80000000" Padding="12,6">
                <DockPanel LastChildFill="False">
                    <TextBlock Name="StreamHud" Foreground="#B0FFFFFF" FontSize="11"
                               FontFamily="{StaticResource FontMono}" VerticalAlignment="Center"/>
                    <Button Content="stop" DockPanel.Dock="Right" Style="{StaticResource BtnQuiet}" Click="Stop_Click"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
