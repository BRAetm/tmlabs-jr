<UserControl x:Class="Labs.RemotePlay.Panels.ControllerMonitorFullView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <SolidColorBrush x:Key="FCtlBody"    Color="#0F172A"/>
        <SolidColorBrush x:Key="FCtlRim"     Color="#182142"/>
        <SolidColorBrush x:Key="FCtlBorder"  Color="#2E3F6A"/>
        <SolidColorBrush x:Key="FCtlSurface" Color="#070A14"/>
        <SolidColorBrush x:Key="FCtlOn"      Color="#1D4ED8"/>
        <SolidColorBrush x:Key="FCtlOnSoft"  Color="#3B82F6"/>
        <SolidColorBrush x:Key="FCtlLabel"   Color="#60A5FA"/>
        <Style x:Key="FLbl" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource FCtlLabel}"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
        </Style>
    </UserControl.Resources>

    <Viewbox Stretch="Uniform">
        <Canvas Width="640" Height="380">

            <!-- Trigger tabs (behind top of body) -->
            <Path Fill="{StaticResource FCtlRim}" Stroke="{StaticResource FCtlBorder}" StrokeThickness="1.5"
                  Data="M 135,92 Q 110,14 205,30 L 245,70 Q 225,94 195,92 Q 165,90 135,92 Z"/>
            <Path Fill="{StaticResource FCtlRim}" Stroke="{StaticResource FCtlBorder}" StrokeThickness="1.5"
                  Data="M 505,92 Q 530,14 435,30 L 395,70 Q 415,94 445,92 Q 475,90 505,92 Z"/>

            <!-- Trigger depression meters -->
            <TextBlock Canvas.Left="168" Canvas.Top="18" Text="LT" Style="{StaticResource FLbl}"/>
            <Grid Canvas.Left="165" Canvas.Top="36" Width="18" Height="50">
                <Border Background="{StaticResource FCtlSurface}" BorderBrush="{StaticResource FCtlBorder}"
                        BorderThickness="1" CornerRadius="3"/>
                <Rectangle x:Name="L2Bar" Fill="{StaticResource FCtlOn}" VerticalAlignment="Bottom" Height="0" Margin="2"/>
            </Grid>
            <TextBlock Canvas.Left="456" Canvas.Top="18" Text="RT" Style="{StaticResource FLbl}"/>
            <Grid Canvas.Left="457" Canvas.Top="36" Width="18" Height="50">
                <Border Background="{StaticResource FCtlSurface}" BorderBrush="{StaticResource FCtlBorder}"
                        BorderThickness="1" CornerRadius="3"/>
                <Rectangle x:Name="R2Bar" Fill="{StaticResource FCtlOn}" VerticalAlignment="Bottom" Height="0" Margin="2"/>
            </Grid>

            <!-- BODY silhouette — three overlapping shapes -->
            <Ellipse Canvas.Left="10"  Canvas.Top="130" Width="220" Height="240"
                     Fill="{StaticResource FCtlBody}"
                     Stroke="{StaticResource FCtlBorder}" StrokeThickness="2"/>
            <Ellipse Canvas.Left="410" Canvas.Top="130" Width="220" Height="240"
                     Fill="{StaticResource FCtlBody}"
                     Stroke="{StaticResource FCtlBorder}" StrokeThickness="2"/>
            <Rectangle Canvas.Left="125" Canvas.Top="110" Width="390" Height="170"
                       RadiusX="60" RadiusY="60"
                       Fill="{StaticResource FCtlBody}"
                       Stroke="{StaticResource FCtlBorder}" StrokeThickness="2"/>
            <!-- seam cover -->
            <Rectangle Canvas.Left="130" Canvas.Top="115" Width="380" Height="160"
                       RadiusX="55" RadiusY="55" Fill="{StaticResource FCtlBody}"/>

            <!-- LB/RB shoulder bumpers (wide pill on the front-top of the body) -->
            <Border Canvas.Left="145" Canvas.Top="112" Width="110" Height="18"
                    Background="{StaticResource FCtlRim}"
                    BorderBrush="{StaticResource FCtlBorder}" BorderThickness="1.5" CornerRadius="9"/>
            <Ellipse x:Name="LedLB" Canvas.Left="190" Canvas.Top="116" Width="20" Height="10"
                     Fill="{StaticResource FCtlSurface}" StrokeThickness="0"/>
            <TextBlock Canvas.Left="192" Canvas.Top="134" Text="LB" Style="{StaticResource FLbl}"/>

            <Border Canvas.Left="385" Canvas.Top="112" Width="110" Height="18"
                    Background="{StaticResource FCtlRim}"
                    BorderBrush="{StaticResource FCtlBorder}" BorderThickness="1.5" CornerRadius="9"/>
            <Ellipse x:Name="LedRB" Canvas.Left="430" Canvas.Top="116" Width="20" Height="10"
                     Fill="{StaticResource FCtlSurface}" StrokeThickness="0"/>
            <TextBlock Canvas.Left="432" Canvas.Top="134" Text="RB" Style="{StaticResource FLbl}"/>

            <!-- Left stick (upper-left quadrant) -->
            <Ellipse Canvas.Left="130" Canvas.Top="150" Width="100" Height="100"
                     Fill="{StaticResource FCtlSurface}"
                     Stroke="{StaticResource FCtlBorder}" StrokeThickness="2"/>
            <Ellipse Canvas.Left="146" Canvas.Top="166" Width="68" Height="68"
                     Fill="{StaticResource FCtlRim}"
                     Stroke="{StaticResource FCtlBorder}" StrokeThickness="1"/>
            <Canvas x:Name="LeftStickCanvas" Canvas.Left="146" Canvas.Top="166" Width="68" Height="68">
                <Ellipse x:Name="LeftStickDot" Width="14" Height="14" Fill="{StaticResource FCtlOn}"
                         Canvas.Left="27" Canvas.Top="27"/>
            </Canvas>
            <TextBlock Canvas.Left="173" Canvas.Top="255" Text="L3" Style="{StaticResource FLbl}"/>
            <Ellipse x:Name="LedL3" Canvas.Left="195" Canvas.Top="258" Width="8" Height="8"
                     Fill="{StaticResource FCtlSurface}" StrokeThickness="0"/>

            <!-- ABXY diamond (upper-right, center ~465, 200) with real Xbox letter labels -->
            <!-- Y (top) -->
            <Ellipse Canvas.Left="450" Canvas.Top="150" Width="34" Height="34"
                     Fill="{StaticResource FCtlSurface}"
                     Stroke="{StaticResource FCtlBorder}" StrokeThickness="1.5"/>
            <Ellipse x:Name="LedY" Canvas.Left="456" Canvas.Top="156" Width="22" Height="22"
                     Fill="{StaticResource FCtlSurface}" StrokeThickness="0"/>
            <TextBlock Canvas.Left="464" Canvas.Top="162" Text="Y" FontFamily="Segoe UI" FontSize="13"
                       FontWeight="Bold" Foreground="{StaticResource FCtlLabel}"
                       IsHitTestVisible="False"/>
            <!-- X (left) -->
            <Ellipse Canvas.Left="415" Canvas.Top="185" Width="34" Height="34"
                     Fill="{StaticResource FCtlSurface}"
                     Stroke="{StaticResource FCtlBorder}" StrokeThickness="1.5"/>
            <Ellipse x:Name="LedX" Canvas.Left="421" Canvas.Top="191" Width="22" Height="22"
                     Fill="{StaticResource FCtlSurface}" StrokeThickness="0"/>
            <TextBlock Canvas.Left="429" Canvas.Top="197" Text="X" FontFamily="Segoe UI" FontSize="13"
                       FontWeight="Bold" Foreground="{StaticResource FCtlLabel}"
                       IsHitTestVisible="False"/>
            <!-- B (right) -->
            <Ellipse Canvas.Left="485" Canvas.Top="185" Width="34" Height="34"
                     Fill="{StaticResource FCtlSurface}"
                     Stroke="{StaticResource FCtlBorder}" StrokeThickness="1.5"/>
            <Ellipse x:Name="LedB" Canvas.Left="491" Canvas.Top="191" Width="22" Height="22"
                     Fill="{StaticResource FCtlSurface}" StrokeThickness="0"/>
            <TextBlock Canvas.Left="499" Canvas.Top="197" Text="B" FontFamily="Segoe UI" FontSize="13"
                       FontWeight="Bold" Foreground="{StaticResource FCtlLabel}"
                       IsHitTestVisible="False"/>
            <!-- A (bottom) -->
            <Ellipse Canvas.Left="450" Canvas.Top="220" Width="34" Height="34"
                     Fill="{StaticResource FCtlSurface}"
                     Stroke="{StaticResource FCtlBorder}" StrokeThickness="1.5"/>
            <Ellipse x:Name="LedA" Canvas.Left="456" Canvas.Top="226" Width="22" Height="22"
                     Fill="{StaticResource FCtlSurface}" StrokeThickness="0"/>
            <TextBlock Canvas.Left="464" Canvas.Top="232" Text="A" FontFamily="Segoe UI" FontSize="13"
                       FontWeight="Bold" Foreground="{StaticResource FCtlLabel}"
                       IsHitTestVisible="False"/>

            <!-- Center cluster — Back / Guide (labs brand) / Start -->
            <Ellipse x:Name="LedBack" Canvas.Left="262" Canvas.Top="175" Width="14" Height="14"
                     Fill="{StaticResource FCtlSurface}"
                     Stroke="{StaticResource FCtlBorder}" StrokeThickness="1.5"/>
            <TextBlock Canvas.Left="253" Canvas.Top="192" Text="back" FontSize="9" Foreground="{StaticResource FCtlLabel}" IsHitTestVisible="False"/>

            <Ellipse Canvas.Left="298" Canvas.Top="162" Width="42" Height="42"
                     Fill="{StaticResource FCtlSurface}"
                     Stroke="{StaticResource FCtlOnSoft}" StrokeThickness="2"/>
            <Ellipse x:Name="LedGuide" Canvas.Left="306" Canvas.Top="170" Width="26" Height="26"
                     Fill="{StaticResource FCtlRim}" StrokeThickness="0"/>
            <Path Canvas.Left="314" Canvas.Top="177" Fill="{StaticResource FCtlOnSoft}" IsHitTestVisible="False"
                  Data="M 0,0 L 4,0 L 4,10 L 12,10 L 12,14 L 0,14 Z"/>

            <Ellipse x:Name="LedStart" Canvas.Left="362" Canvas.Top="175" Width="14" Height="14"
                     Fill="{StaticResource FCtlSurface}"
                     Stroke="{StaticResource FCtlBorder}" StrokeThickness="1.5"/>
            <TextBlock Canvas.Left="353" Canvas.Top="192" Text="start" FontSize="9" Foreground="{StaticResource FCtlLabel}" IsHitTestVisible="False"/>

            <!-- D-pad (lower-left, solid cross with direction highlights) -->
            <Ellipse Canvas.Left="220" Canvas.Top="240" Width="100" Height="100"
                     Fill="{StaticResource FCtlSurface}"
                     Stroke="{StaticResource FCtlBorder}" StrokeThickness="1"/>
            <Path Fill="{StaticResource FCtlRim}" Stroke="{StaticResource FCtlBorder}" StrokeThickness="1.5"
                  Data="M 253,253 L 287,253 L 287,277 L 311,277 L 311,303 L 287,303 L 287,327 L 253,327 L 253,303 L 229,303 L 229,277 L 253,277 Z"/>
            <!-- Direction highlights -->
            <Ellipse x:Name="LedDUp"    Canvas.Left="256" Canvas.Top="256" Width="28" Height="16"
                     Fill="{StaticResource FCtlSurface}" StrokeThickness="0"/>
            <Ellipse x:Name="LedDDown"  Canvas.Left="256" Canvas.Top="308" Width="28" Height="16"
                     Fill="{StaticResource FCtlSurface}" StrokeThickness="0"/>
            <Ellipse x:Name="LedDLeft"  Canvas.Left="234" Canvas.Top="284" Width="16" Height="12"
                     Fill="{StaticResource FCtlSurface}" StrokeThickness="0"/>
            <Ellipse x:Name="LedDRight" Canvas.Left="290" Canvas.Top="284" Width="16" Height="12"
                     Fill="{StaticResource FCtlSurface}" StrokeThickness="0"/>

            <!-- Right stick (lower-right quadrant) -->
            <Ellipse Canvas.Left="340" Canvas.Top="240" Width="100" Height="100"
                     Fill="{StaticResource FCtlSurface}"
                     Stroke="{StaticResource FCtlBorder}" StrokeThickness="2"/>
            <Ellipse Canvas.Left="356" Canvas.Top="256" Width="68" Height="68"
                     Fill="{StaticResource FCtlRim}"
                     Stroke="{StaticResource FCtlBorder}" StrokeThickness="1"/>
            <Canvas x:Name="RightStickCanvas" Canvas.Left="356" Canvas.Top="256" Width="68" Height="68">
                <Ellipse x:Name="RightStickDot" Width="14" Height="14" Fill="{StaticResource FCtlOn}"
                         Canvas.Left="27" Canvas.Top="27"/>
            </Canvas>
            <TextBlock Canvas.Left="383" Canvas.Top="345" Text="R3" Style="{StaticResource FLbl}"/>
            <Ellipse x:Name="LedR3" Canvas.Left="405" Canvas.Top="348" Width="8" Height="8"
                     Fill="{StaticResource FCtlSurface}" StrokeThickness="0"/>

        </Canvas>
    </Viewbox>
</UserControl>
